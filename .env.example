# Obtido em https://my.telegram.org
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Token do bot criado no @BotFather
BOT_TOKEN=123456789:AAF...

# Seu chat_id pessoal (obter via @userinfobot)
OWNER_CHAT_ID=987654321

# IDs ou usernames dos grupos a monitorar (separados por vírgula)
# Exemplo: -1001234567890,promosdobrasil,cupomnarede
MONITORED_GROUPS=-1001234567890,promosdobrasil

# Preço máximo padrão em reais (0 = sem limite)
DEFAULT_MAX_PRICE=0.0

# Caminho do banco SQLite
DATABASE_PATH=promo_bot.db

# Nome do arquivo de sessão Telethon
SESSION_NAME=promo_bot_session
